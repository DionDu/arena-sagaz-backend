# Dados de treino e modelos treinados — NÃO versionados aqui (backup no Google
# Drive). São grandes (~650MB) e/ou regeneráveis pelo gerador_dados/ + tablebase;
# o git guarda só o CÓDIGO e os RELATÓRIOS. Decisão de 2026-07-07.
/dados/
/modelos/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Ambiente virtual
.venv/
venv/
env/
.venv_tf/
.venv_gpu/

# Variáveis de ambiente
.env

# Credenciais do Firebase Admin SDK (NUNCA versionar — vão por variável de ambiente no Railway)
*firebase-adminsdk*.json
arena-sagaz-*-firebase-adminsdk.json
# Arquivos de config do Firebase do app (gerados por ambiente)
google-services.json
GoogleService-Info.plist

# Testes
.pytest_cache/
.coverage
htmlcov/

# Binários de dataset e modelo — fora do git (backup no Drive; ver /dados/ e /modelos/).
*.npy
*.npz
*.tflite
*.keras

# IDE
.vscode/
.idea/
*.swp
*.swo

# SO
.DS_Store
Thumbs.db

# Claude Code local settings (não versionar)
.claude/

# Oraculo tablebase (gerado, ~2GB)
dados/oraculo_pontinhos/

# Análises e scripts temporários (artefatos ML gerados — não versionar). O
# tmp_analise/ tinha ~55 mil arquivos rastreados (PNG/NPY/JSON de "retratos de
# divergência"), removidos do rastreamento em jul/2026 (MEL-03 da revisão de
# segurança). Os arquivos continuam no disco; só param de ser versionados.
tmp_analise/
tmp_*.py
# visualizacoes/ = ~2.5 mil pares PNG+MD de "retratos de partida" gerados pelo
# avaliador (regeneráveis) — mesmo caso do tmp_analise/ acima. Fora do git.
/visualizacoes/
